          <mxGeometry x="360" y="90" width="260" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="c2" value="AdkEnrichmentAgent&#10;reads MongoStore -&gt; ctx.member&#10;ctx.recent_events = [...]&#10;LLM -&gt; ctx.narrative" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="660" y="90" width="260" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="c3" value="AdkScoringAgent&#10;LLM -&gt; ScoringResponse&#10;sets ctx.risk_score (RiskScore)&#10;dimension, score, citations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="60" y="280" width="260" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="c4" value="AdkRecommendationAgent&#10;LLM -&gt; RecommendationResponse&#10;coerce -&gt; DispositionAction&#10;sets ctx.disposition" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="360" y="280" width="260" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="c5" value="Pipeline persists&#10;risk_scores · dispositions · case_files&#10;CaseFile.agent_trace = ctx.audit_trace" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="660" y="280" width="260" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="g1" style="endArrow=classic;html=1" edge="1" parent="1" source="c0" target="c1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="g2" style="endArrow=classic;html=1" edge="1" parent="1" source="c1" target="c2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="g3" style="endArrow=classic;html=1" edge="1" parent="1" source="c2" target="c3">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="g4" style="endArrow=classic;html=1" edge="1" parent="1" source="c3" target="c4">
