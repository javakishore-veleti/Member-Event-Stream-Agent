        <mxCell id="g5" style="endArrow=classic;html=1" edge="1" parent="1" source="c4" target="c5">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="note9" value="Every stage appends to ctx.audit_trace. The trailing CaseFile freezes that trace + an inputs_hash so a HIPAA reviewer can replay exactly which agents (rule-based or ADK) drove the decision." style="text;html=1;align=left;fontSize=11;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="60" y="430" width="900" height="40" as="geometry"/>
