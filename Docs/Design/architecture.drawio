  <diagram name="4. Event Lifecycle" id="page-lifecycle">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title4" value="Event Lifecycle — From Source System to Care Team Notification" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="1120" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="s1" value="1. Source system&#10;emits raw event&#10;(ELIGIBILITY, CLAIM,&#10;PHARMACY, etc.)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="40" y="100" width="180" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="s2" value="2. Kafka topic&#10;member.events.*&#10;partitioned by&#10;member_id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1">
          <mxGeometry x="240" y="100" width="180" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="s3" value="3. member_events&#10;async consumer pulls&#10;(idempotent on&#10;event_id)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="440" y="100" width="180" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="s4" value="4. Normalize +&#10;validate (Pydantic)&#10;FHIR-aligned&#10;attribute set" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366" vertex="1" parent="1">
          <mxGeometry x="640" y="100" width="180" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="s5" value="5. Persist raw +&#10;normalized to&#10;member_record&#10;(Member 360)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="840" y="100" width="220" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="s6" value="6. Triage Agent&#10;classify family +&#10;pick use case" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6" vertex="1" parent="1">
          <mxGeometry x="40" y="260" width="180" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="s7" value="7. Enrichment Agent&#10;join Member 360 +&#10;recent events +&#10;active meds" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6" vertex="1" parent="1">
          <mxGeometry x="240" y="260" width="200" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="s8" value="8. Scoring Agent&#10;rule + LLM hybrid&#10;produces RiskScore&#10;with citations" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6" vertex="1" parent="1">
          <mxGeometry x="460" y="260" width="200" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="s9" value="9. Recommendation&#10;Agent → Disposition" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6" vertex="1" parent="1">
          <mxGeometry x="680" y="260" width="200" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="s10" value="10. Persist RiskScore +&#10;Disposition + immutable&#10;CaseFile (HIPAA audit)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="900" y="260" width="220" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="s11" value="11. Notify&#10;notify_care_manager /&#10;open_outreach /&#10;queue_pa_review /&#10;escalate_fwa" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf" vertex="1" parent="1">
          <mxGeometry x="40" y="430" width="220" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="s12" value="12. Care team opens&#10;case via LLM client&#10;(MCP, scoped tools,&#10;PHI redacted)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00" vertex="1" parent="1">
          <mxGeometry x="300" y="430" width="240" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="l1" style="endArrow=classic;html=1;rounded=0" edge="1" parent="1" source="s1" target="s2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="l2" style="endArrow=classic;html=1;rounded=0" edge="1" parent="1" source="s2" target="s3"><mxGeometry relative="1" as="geometry"/></mxCell>
