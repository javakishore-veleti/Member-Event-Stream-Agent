        <mxCell id="g-seam-1" value="Protocol LlmClient&#10;  complete_scoring(prompt, context)&#10;  complete_triage(prompt, context)&#10;  complete_narrative(prompt, context)&#10;  complete_recommendation(prompt, context)" style="text;html=1;align=left;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
