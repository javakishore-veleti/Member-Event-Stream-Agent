          <mxGeometry x="20" y="20" width="1120" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="proto" value="«Protocol» LlmClient&#10;---&#10;+ async complete_scoring(prompt, context) -&gt; ScoringResponse&#10;+ async complete_triage(prompt, context) -&gt; TriageResponse&#10;+ async complete_narrative(prompt, context) -&gt; NarrativeResponse&#10;+ async complete_recommendation(prompt, context) -&gt; RecommendationResponse" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontFamily=Courier New;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="360" y="80" width="460" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="fake" value="FakeLlmClient&#10;---&#10;- _scoring: list[ScoringResponse]&#10;- _triage: list[TriageResponse]&#10;- _narrative: list[NarrativeResponse]&#10;- _recommendation: list[RecommendationResponse]&#10;- _raise_on_next: bool&#10;+ scoring_calls / triage_calls / ... captured for assertions" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontFamily=Courier New;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="40" y="320" width="460" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="real" value="GoogleAdkClient&#10;---&#10;- _model: str  (default gemini-2.0-flash)&#10;- _client: google.genai.Client (deferred import)&#10;+ _generate_json(prompt, context) -&gt; dict&#10;  (one shared helper used by all 4 complete_* methods)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontFamily=Courier New;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="680" y="320" width="460" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="resp" value="@dataclass typed responses&#10;---&#10;ScoringResponse(score: float, rationale: str, citations: list[str])&#10;TriageResponse(use_case: str | None, rationale: str)&#10;NarrativeResponse(narrative: str)&#10;RecommendationResponse(action: str, notes: str)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontFamily=Courier New;fontSize=11" vertex="1" parent="1">
