        <mxCell id="t7" value="ADK test surface — what each test file proves about the ADK code" style="text;html=1;align=center;verticalAlign=middle;fontSize=15;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="1120" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="r1" value="tests/care_decisioning/test_scoring_adk.py" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="520" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="r1b" value="happy path — FakeLlmClient ScoringResponse round-trips into RiskScore&#10;source=adk lands in audit_trace&#10;LLM error -&gt; rule-based fall-back path runs&#10;Pipeline(scoring_agent=AdkScoringAgent(...)) wires the seam end to end" style="text;html=1;align=left;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="60" y="115" width="500" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="r2" value="tests/care_decisioning/test_triage_adk.py" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="600" y="80" width="540" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="r2b" value="LLM picks valid use_case -&gt; ctx.use_case set, skip stays False&#10;LLM picks unknown value -&gt; ctx.skip True, skip_reason set&#10;LLM raises -&gt; rule-based fall-back routes office_visit -&gt; CARE_GAP" style="text;html=1;align=left;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="620" y="115" width="500" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="r3" value="tests/care_decisioning/test_enrichment_recommendation_adk.py" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="270" width="520" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="r3b" value="enrichment attaches narrative + still does the DB read&#10;enrichment falls back silently on LLM error&#10;recommendation picks DispositionAction; unknown action -&gt; rule fall-back&#10;Pipeline with all 4 ADK variants wired produces a CaseFile end to end" style="text;html=1;align=left;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="60" y="305" width="500" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="r4" value="tests/care_decisioning/test_adk_factory.py" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="600" y="270" width="540" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="r4b" value="LLM_PROVIDER=stub -&gt; FakeLlmClient&#10;LLM_PROVIDER=garbage -&gt; ValueError (fail-fast at startup)&#10;LLM_PROVIDER=google_adk -&gt; either constructs the real client&#10;or raises a `pip install &quot;.[adk]&quot;` ImportError when the extra is missing&#10;module imports cleanly without google-genai installed" style="text;html=1;align=left;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="620" y="305" width="500" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="r5" value="tests/care_decisioning/test_rescore.py" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="480" width="1100" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="r5b" value="Rescorer writes a fresh RiskScore + Disposition + immutable CaseFile (model_version=v0.0.1-rules-rescore)&#10;Late claim worker rescorers existing dimensions and persists a SECOND RiskScore for the same dim (rescore appended, not overwrote)&#10;FWA is skipped — main Pipeline already routes CLAIM to FWA via Triage; rescoring it would double-write&#10;non-claim events are ignored entirely&#10;Rescorer takes the same agent= knobs Pipeline does, so an LLM-driven rescore is one constructor arg away" style="text;html=1;align=left;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="60" y="515" width="1080" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="note7" value="All ADK tests use FakeLlmClient — the suite never makes a network call. CI run on every push stays under one second on the ADK tests alone." style="text;html=1;fontSize=10;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="40" y="660" width="1100" height="20" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
