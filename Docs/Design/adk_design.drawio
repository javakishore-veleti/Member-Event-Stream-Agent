        <mxCell id="i2" style="endArrow=block;endFill=0;html=1;rounded=0" edge="1" parent="1" source="real" target="proto">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="i3" style="endArrow=open;html=1;dashed=1" edge="1" parent="1" source="proto" target="resp">
          <mxGeometry relative="1" as="geometry"/>
          <mxCell id="i3l" value="returns" style="text;html=1;fontSize=10" vertex="1" parent="1"/>
