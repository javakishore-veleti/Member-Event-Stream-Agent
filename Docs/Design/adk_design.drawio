        </mxCell>
        <mxCell id="g-seam-4" value="GoogleAdkClient — google-genai wrapper, deferred import, JSON-only completions" style="text;html=1;align=left;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="60" y="310" width="480" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="g-seam-5" value="build_llm_client(settings) — picks stub | google_adk | error" style="text;html=1;align=left;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="60" y="332" width="480" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="g-agents" value="ADK agent variants (care_decisioning/adk/*_adk.py)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="600" y="80" width="540" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="g-agents-1" value="AdkTriageAgent      — LLM picks RiskDimension, falls back to TriageAgent" style="text;html=1;align=left;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="620" y="115" width="520" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="g-agents-2" value="AdkEnrichmentAgent  — DB read first, LLM narrative -&gt; ctx.narrative" style="text;html=1;align=left;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="620" y="140" width="520" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="g-agents-3" value="AdkScoringAgent     — LLM ScoringResponse, falls back to ScoringAgent" style="text;html=1;align=left;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="620" y="165" width="520" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="g-agents-4" value="AdkRecommendationAgent — LLM picks DispositionAction, coerce + fall back" style="text;html=1;align=left;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="620" y="190" width="520" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="g-agents-5" value="Every variant satisfies the same Agent Protocol from base.py.&#10;Each one records source=adk on success and fallback=True on error&#10;in ctx.audit_trace, which freezes into the immutable CaseFile." style="text;html=1;align=left;fontSize=11;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="620" y="220" width="520" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="g-agents-6" value="Rescorer (care_decisioning/rescore.py)&#10;runs Enrichment -&gt; Scoring -&gt; Recommendation directly,&#10;accepts the same ADK agent knobs Pipeline does" style="text;html=1;align=left;fontSize=11;fontFamily=Courier New;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="620" y="290" width="520" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="g-pipe" value="care_decisioning/pipeline.py — Pipeline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="390" width="1100" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="g-pipe-1" value="Pipeline(store, *, triage_agent=, enrichment_agent=, scoring_agent=, recommendation_agent=)&#10;Owns stage order + the storage write path. Defaults are the rule-based agents.&#10;Pass the AdkXxxAgent variants (built around build_llm_client(settings)) to flip a deployment to LLM-driven decisions.&#10;Persists RiskScore, Disposition, and an immutable CaseFile carrying the full ctx.audit_trace + an inputs_hash." style="text;html=1;align=left;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="60" y="425" width="1080" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="g-cfg" value="config.py + settings + .env" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="540" width="540" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="g-cfg-1" value="LLM_PROVIDER=stub | google_adk&#10;LLM_MODEL=gemini-2.0-flash&#10;LLM_API_KEY=...&#10;PAYER_ORG_ID=dev-payer&#10;MONGO_URI=memory:// | mongodb://...&#10;KAFKA_BROKERS=memory:// | broker1:9092,broker2:9092" style="text;html=1;align=left;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="60" y="575" width="500" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="g-pkg" value="Optional [adk] extra (pyproject.toml)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="600" y="540" width="540" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="g-pkg-1" value="pip install &quot;.[adk]&quot;&#10;pulls google-adk -&gt; google-genai (the SDK ADK builds on)&#10;Only google_adk_client.py imports from the google namespace, and the&#10;import is deferred to GoogleAdkClient.__init__ so the rest of the package&#10;and the unit suite never need google-adk installed.&#10;Misconfigured deploys (LLM_PROVIDER=google_adk without the extra) raise&#10;a clear `pip install &quot;.[adk]&quot;` ImportError at startup." style="text;html=1;align=left;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
          <mxGeometry x="620" y="575" width="500" height="140" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="2. LlmClient Class Diagram" id="adk-2">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="826" math="0" shadow="0">
