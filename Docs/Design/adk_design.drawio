          <mxGeometry x="60" y="200" width="480" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="g-seam-3" value="FakeLlmClient — queued canned responses for tests, raise_on_next flag" style="text;html=1;align=left;fontSize=11;fontFamily=Courier New" vertex="1" parent="1">
