# Copy to .env and adjust for local dev. None of these values should be used in shared envs.

MONGO_URI=memory://
MONGO_DB=mesa
PAYER_ORG_ID=dev-payer

# Set to memory:// for the in-process synthetic backend, or to a real broker list:
#   KAFKA_BROKERS=localhost:9092
KAFKA_BROKERS=memory://
KAFKA_TOPIC=member.events

# LLM provider key (left blank in dev — scoring agent stays rule-based until set)
LLM_API_KEY=

# Token presented by MCP clients (must match what the analyst's LLM client sends)
MCP_TOKEN=dev-token

LOG_LEVEL=INFO
